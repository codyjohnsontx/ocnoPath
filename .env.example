# Leave AI_PROVIDER unset to use deterministic source-grounded fallback explanations.

# Free local AI option
AI_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# Hosted open-model option (Groq free tier) — recommended for a deployed app.
# Groq is OpenAI-API-compatible, so it reuses the openai provider path via OPENAI_BASE_URL.
# Verify the current model id at https://console.groq.com/docs/models
# AI_PROVIDER=openai
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_your_groq_key
# OPENAI_MODEL=llama-3.3-70b-versatile

# Paid API option (OpenAI)
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Future database cache
# DATABASE_URL=postgresql://user:password@localhost:5432/oncopath
